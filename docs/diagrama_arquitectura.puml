@startuml
title Sistema de Gestión de Préstamos - Arquitectura en Capas

skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName Arial

' Colores por capa
skinparam package {
  BackgroundColor<<views>> #e1f5fe
  BackgroundColor<<controllers>> #ffec99
  BackgroundColor<<models>> #b2f2bb
  BackgroundColor<<core>> #d0bfff
  BackgroundColor<<data>> #dee2e6
}

package "Capa de Presentación" <<views>> {
    [Menu]
}

package "Capa de Control" <<controllers>> {
    [EmployeeController]
    [LoanController]
    [PayController]
    [StatsController]
}

package "Capa de Modelo" <<models>> {
    [Employee]
    [Loan]
    [Pay]
}

package "Capa de Utilidades" <<core>> {
    [CrudInterface]
    [ValidationMixin]
    [LogMixin]
    [JsonManager]
    [ConsoleUtils]
}

package "Capa de Datos" <<data>> {
    [Employee.json]
    [Loan.json]
    [Pay.json]
}

' Relaciones
Menu --> EmployeeController
Menu --> LoanController
Menu --> PayController
Menu --> StatsController

EmployeeController --> CrudInterface
EmployeeController --> ValidationMixin
EmployeeController --> LogMixin
EmployeeController --> JsonManager
LoanController --> JsonManager
PayController --> JsonManager

JsonManager --> Employee.json
JsonManager --> Loan.json
JsonManager --> Pay.json

EmployeeController --> Employee
LoanController --> Loan
PayController --> Pay

@enduml
